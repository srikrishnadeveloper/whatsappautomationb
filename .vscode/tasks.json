{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Kill Ports",
      "type": "shell",
      "command": "Get-Process -Name node -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue; Start-Sleep -Seconds 1; Write-Host '✓ Ports cleared'",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "npx ts-node-dev --respawn --transpile-only src/index.ts",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "dependsOn": "Kill Ports",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[INFO\\]",
          "endsPattern": "running on port"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-split",
        "title": "Backend :8080"
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npx vite --port 5173",
      "options": {
        "cwd": "${workspaceFolder}/frontend/frontend"
      },
      "dependsOn": "Kill Ports",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-split",
        "title": "Frontend :5173"
      }
    },
    {
      "label": "Dev: Start All (Split)",
      "dependsOn": ["Start Backend", "Start Frontend"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-split"
      }
    }
  ]
}
